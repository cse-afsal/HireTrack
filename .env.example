# 1. Database Configuration
# For local development, this uses SQLite. 
# For production, change this to a PostgreSQL connection string (e.g., from Supabase, Neon, or AWS RDS).
DATABASE_URL="file:./dev.db"

# 2. NextAuth Configuration
# Run `openssl rand -base64 32` in your terminal to generate a secure secret.
NEXTAUTH_SECRET="your-super-secret-production-key"
# Change this to your live domain in production (e.g., https://yourdomain.com)
NEXTAUTH_URL="http://localhost:3000"

# 3. Google OAuth Authentication
# Get these by creating an OAuth 2.0 Client ID in the Google Cloud Console.
# Important: Add your NEXTAUTH_URL + "/api/auth/callback/google" to the Authorized redirect URIs in Google Cloud.
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# 4. Google Gemini AI 
# Required for powering the mock interviews and resume analyzer.
# Get this from Google AI Studio (aistudio.google.com).
GEMINI_API_KEY="your_gemini_api_key_here"
